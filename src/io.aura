use runtime = "runtime";

def print(text: String) -> Void {
    runtime.write(1, runtime.bytes_from_string(text));
}

def println(text: String) -> Void {
    print(text);
    print("\n");
}

def printerr(text: String) -> Void {
    runtime.write(2, runtime.bytes_from_string(text));
}

def printerrln(text: String) -> Void {
    printerr(text);
    printerr("\n");
}
